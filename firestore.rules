rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Checks if the authenticated user is the linked partner for a given shopId
    function isLinkedPartner(shopId) {
      return request.auth != null &&
        get(/databases/$(database)/documents/partners/$(request.auth.uid)).data.shopId == shopId;
    }

    match /users/{userId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }

    match /partners/{partnerId} {
      allow read, write: if request.auth != null && request.auth.uid == partnerId;
    }

    match /riders/{riderId} {
      allow read, write: if request.auth != null && request.auth.uid == riderId;
    }

    match /shops/{shopId} {
      allow read: if true;
      allow write: if request.auth != null && isLinkedPartner(shopId);
    }

    match /menuItems/{itemId} {
      allow read: if true;
      allow create: if request.auth != null && isLinkedPartner(request.resource.data.shopId);
      allow update, delete: if request.auth != null && isLinkedPartner(resource.data.shopId);
    }

    match /orders/{orderId} {
      allow read: if request.auth != null &&
        (request.auth.uid == resource.data.customerId ||
         request.auth.uid == resource.data.riderId ||
         isLinkedPartner(resource.data.shopId) ||
         // Riders can see unassigned orders from CONFIRMED onwards
         (resource.data.riderId == null &&
          (resource.data.status == 'confirmed' ||
           resource.data.status == 'preparing' ||
           resource.data.status == 'ready')));
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.customerId;
      allow update: if request.auth != null &&
        (request.auth.uid == resource.data.customerId ||
         request.auth.uid == resource.data.riderId ||
         isLinkedPartner(resource.data.shopId));
    }

    match /categories/{catId} {
      allow read: if true;
      allow write: if false;
    }

    match /notifications/{notifId} {
      allow read, write: if request.auth != null &&
        request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
    }

    match /favourites/{favId} {
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }

    match /coupons/{couponId} {
      allow read: if request.auth != null;
      allow write: if false;
    }

    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null &&
        request.auth.uid == request.resource.data.customerId;
      allow update, delete: if request.auth != null &&
        request.auth.uid == resource.data.customerId;
    }

    match /addresses/{addressId} {
      allow read, delete: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null && request.auth.uid == request.resource.data.userId;
      allow update: if request.auth != null && request.auth.uid == resource.data.userId;
    }
  }
}
